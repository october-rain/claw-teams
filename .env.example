# Required: gateway auth token shared by all swarm instances
# Generate one with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace_with_random_token

# Required for Kimi / Moonshot
MOONSHOT_API_KEY=replace_with_moonshot_key

# Optional additional providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional browser endpoint
CHROME_CDP_URL=

# Optional: cap Node memory per OpenClaw container (helps avoid OOM with multi-agent)
OPENCLAW_NODE_OPTIONS=--max-old-space-size=640

# Optional: override host repository path mounted into every agent container
# Default is project root "."
SWARM_SHARED_REPO_PATH=

# Optional security flag (normally keep empty)
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
