# Gateway auth token (required). Generate one: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace_with_random_token

# Kimi / Moonshot API key (recommended for your setup)
MOONSHOT_API_KEY=replace_with_moonshot_key

# Optional additional providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional browser endpoint
CHROME_CDP_URL=

# Runtime settings
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_CONTAINER_NAME=openclaw-1-gateway
OPENCLAW_CONFIG_DIR=./data/openclaw-1/config
OPENCLAW_WORKSPACE_DIR=./data/openclaw-1/workspace
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
